{
    "name": "@onlook/next-template",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "prisma generate && next dev",
        "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true})}catch(e){}\" && prisma generate && next dev",
        "build": "prisma generate && next build",
        "start": "next start",
        "lint": "next lint",
        "format": "prettier --write .",
        "postinstall": "prisma generate",
        "db:push": "prisma db push",
        "db:seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/client": "^6.19.2",
        "@radix-ui/react-slot": "^1.1.0",
        "bcryptjs": "^3.0.3",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "framer-motion": "^12.35.0",
        "lucide-react": "^0.438.0",
        "next": "14.2.23",
        "next-auth": "^4.24.13",
        "prisma": "^6.19.2",
        "react": "^18",
        "react-day-picker": "^9.14.0",
        "react-dom": "^18",
        "resend": "^6.9.3",
        "sonner": "^2.0.7",
        "tailwind-merge": "^2.5.2",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^20",
        "@types/react": "^18",
        "@types/react-dom": "^18",
        "eslint": "^8",
        "eslint-config-next": "^15.1.6",
        "postcss": "^8",
        "prettier": "^3.3.3",
        "tailwindcss": "^3.4.1",
        "typescript": "^5"
    }
}
